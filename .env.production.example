# ── PostgreSQL ────────────────────────────────────────────────────────────────
PG_USER=yam
PG_PASSWORD=CHANGE_ME_STRONG_PASSWORD
PG_DB=yam
DATABASE_URL=postgres://yam:CHANGE_ME_STRONG_PASSWORD@postgres:5432/yam

# ── ScyllaDB ─────────────────────────────────────────────────────────────────
SCYLLA_HOSTS=scylla:9042
SCYLLA_KEYSPACE=yam
SCYLLA_SMP=2
SCYLLA_MEMORY=2G

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD
REDIS_URL=redis://:CHANGE_ME_STRONG_PASSWORD@redis:6379
REDIS_MAXMEMORY=512mb

# ── JWT (generate with: openssl rand -base64 48) ────────────────────────────
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_DIFFERENT_RANDOM_64_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── File Storage ─────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=/data/uploads

# ── imgproxy ─────────────────────────────────────────────────────────────────
IMGPROXY_URL=http://imgproxy:8080

# ── Ports (internal, don't change unless you change nginx.prod.conf) ─────────
API_PORT=3000
GATEWAY_PORT=3001
ADMIN_PORT=3002
NODE_ENV=production

# ── Public port (host:container) ─────────────────────────────────────────────
PUBLIC_PORT=80

# ── CORS (your domain) ──────────────────────────────────────────────────────
CORS_ORIGINS=https://yam.example.com

# ── OTP (disable demo in production!) ────────────────────────────────────────
OTP_DEMO_ENABLED=false
# OTP_DEMO_CODE=000000
# OTP_DEMO_PHONES=

# ── Limits ───────────────────────────────────────────────────────────────────
MAX_GROUP_SIZE=200
MAX_MESSAGE_LENGTH=4096
MAX_FILE_SIZE_MB=50
RATE_LIMIT_MESSAGES_PER_MIN=60
