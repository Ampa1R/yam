# PostgreSQL
DATABASE_URL=postgres://yam:yam_dev@localhost:5432/yam
PG_POOL_SIZE=20
PG_IDLE_TIMEOUT=30
PG_CONNECT_TIMEOUT=10

# ScyllaDB
SCYLLA_HOSTS=localhost:9042
SCYLLA_KEYSPACE=yam
SCYLLA_DC=datacenter1
# SCYLLA_POOL_LOCAL=2

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-use-random-64-chars
JWT_REFRESH_SECRET=change-me-in-production-use-random-64-chars-different
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# File Storage (STORAGE_LOCAL_PATH must be absolute — worker runs from a different cwd)
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=/absolute/path/to/yam/uploads
# STORAGE_S3_BUCKET=yam-files
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_ENDPOINT=http://localhost:9000

# imgproxy
IMGPROXY_URL=http://localhost:8081

# App
API_PORT=3000
GATEWAY_PORT=3001
ADMIN_PORT=3002
NODE_ENV=development

# CORS (comma-separated origins; empty = allow all in dev)
# CORS_ORIGINS=https://yam.example.com,https://admin.yam.example.com

# OTP Demo Mode
OTP_DEMO_ENABLED=true
OTP_DEMO_CODE=000000
OTP_DEMO_PHONES=+79000000001,+79000000002,+79000000003,+79000000004,+79000000005,+79000000006,+79000000007,+79000000008,+79000000009

# Limits
MAX_GROUP_SIZE=200
MAX_MESSAGE_LENGTH=4096
MAX_FILE_SIZE_MB=50
RATE_LIMIT_MESSAGES_PER_MIN=60
